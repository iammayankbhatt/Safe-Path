# SafePath Backend Environment Variables
# Copy this file to .env and fill in your values

# Database
DATABASE_URL=postgresql://username:password@localhost:5432/safepath
# OR individual vars:
DB_HOST=localhost
DB_PORT=5432
DB_NAME=safepath
DB_USER=postgres
DB_PASSWORD=your_app_password

# Server
PORT=5000
NODE_ENV=development
FRONTEND_URL=http://localhost:3000

# Twilio SMS (for panic alerts)
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token
TWILIO_PHONE_NUMBER=+1234567890

# Email (for police alerts)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_email@gmail.com
EMAIL_PASSWORD=your_app_password
EMAIL_FROM=SafePath Alert <alerts@safepath.in>

# ML Microservice
ML_SERVICE_URL=http://localhost:5001

# Police Email Map (district level)
POLICE_EMAIL_MEERUT=meerutpolice@up.gov.in
POLICE_EMAIL_DEFAULT=up100@up.gov.in

# JWT (optional, for admin)
JWT_SECRET=your_super_secret_jwt_key_change_this